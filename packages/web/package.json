    "@types/lodash.merge": "4.6.7",
    "@types/react": "18.3.26",
    "@types/react-dom": "18.0.5",
    "bs58": "5.0.0",
    "chroma-js": "3.1.2",
    "chromatic": "15.0.0",
    "classnames": "2.5.1",
    "concurrently": "8.2.2",
    "eslint-config-custom": "workspace:*",
    "eslint-plugin-storybook": "10.2.0",
    "glob": "13.0.6",
    "http-server": "14.1.1",
    "identity-obj-proxy": "3.0.0",
    "immer": "10.1.1",
    "input-otp": "1.4.2",
    "jest": "30.2.0",
    "js-cookie": "3.0.1",
    "lodash.merge": "4.6.2",
    "nanoid": "3.3.11",
    "preact": "10.19.2",
