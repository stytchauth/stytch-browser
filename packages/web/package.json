{
  "name": "@stytch/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006 --ci",
    "build-storybook": "storybook build --stats-json",
    "build-storybook:test": "storybook build --stats-json --test",
    "test-storybook": "test-storybook",
    "test-storybook:static": "yarn concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"yarn http-server storybook-static --port 6006 --silent\" \"yarn wait-on -t 30s tcp:127.0.0.1:6006 && yarn test-storybook\"",
    "strings": "rm -f messages/en.po messages/b2b/en.po messages/adminPortal/en.po && lingui extract-experimental --clean && lingui compile && tsx scripts/generate-po-types.ts",
    "chromatic": "chromatic --exit-zero-on-changes"
  },
  "license": "MIT",
  "author": "Stytch",
  "sideEffects": [
    "*.css",
    "*/MuiClassNameSetup"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./headless": "./src/index.headless.ts",
    "./common": "./src/common.ts",
    "./compat": "./src/ui/compat/index.ts",
    "./b2b": "./src/b2b/index.ts",
    "./b2b/headless": "./src/b2b/index.headless.ts",
    "./adminPortal": "./src/adminPortal/index.ts",
    "./adminPortal/types": "./src/adminPortal/types.ts",
    "./types": "./src/external-types.ts",
    "./react/b2c": "./src/ui/react/b2c/index.ts",
    "./react/b2b": "./src/ui/react/b2b/index.ts",
    "./react/adminPortal": "./src/ui/react/adminPortal/index.ts"
  },
  "dependencies": {
    "@types/google-one-tap": "^1.2.0",
    "type-fest": "4.15.0"
  },
  "devDependencies": {
    "@babel/core": "7.27.1",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.0",
    "@lingui/cli": "5.9.0",
    "@lingui/core": "5.9.0",
    "@lingui/format-po": "5.9.0",
    "@lingui/message-utils": "5.9.0",
    "@lingui/react": "5.9.0",
    "@lingui/vite-plugin": "5.9.0",
    "@mui/icons-material": "6.4.0",
    "@mui/material": "6.4.0",
    "@preact/compat": "17.1.2",
    "@preact/preset-vite": "2.10.2",
    "@storybook/addon-a11y": "10.2.0",
    "@storybook/addon-links": "10.2.0",
    "@storybook/addon-themes": "10.2.0",
    "@storybook/preact-vite": "10.2.0",
    "@storybook/react": "10.2.0",
    "@storybook/test-runner": "0.24.2",
    "@stytch/core": "workspace:*",
    "@stytch/internal-assets": "workspace:*",
    "@stytch/internal-build-config": "workspace:*",
    "@stytch/internal-jest-config": "workspace:*",
    "@stytch/internal-mocks": "workspace:*",
    "@stytch/internal-style-injector": "workspace:*",
    "@stytch/internal-tsconfigs": "workspace:*",
    "@stytch/js-utils": "workspace:*",
    "@svgr/cli": "8.1.0",
    "@swc/core": "1.11.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/preact": "3.2.4",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/chroma-js": "3.1.2",
    "@types/glob": "9.0.0",
    "@types/grecaptcha": "3.0.4",
    "@types/jest": "30.0.0",
