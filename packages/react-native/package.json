{
  "name": "@stytch/react-native",
  "version": "0.72.0",
  "description": "Stytch's official React Native Library",
  "summary": "Stytch's official React Native Library",
  "type": "commonjs",
  "main": "./dist/cjs-legacy/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "require": {
        "development": "./dist/cjs-dev/index.cjs",
        "production": "./dist/cjs/index.cjs",
        "default": "./dist/cjs/index.cjs"
      },
      "default": "./dist/cjs/index.cjs"
    },
    "./b2b": {
      "types": "./dist/types/b2b/index.d.ts",
      "require": {
        "development": "./dist/cjs-dev/b2b/index.cjs",
        "production": "./dist/cjs/b2b/index.cjs",
        "default": "./dist/cjs/b2b/index.cjs"
      },
      "default": "./dist/cjs/b2b/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "b2b",
    "android",
    "ios",
    "*.podspec",
    "recaptcha",
    "src/native-module/*.ts"
  ],
  "installConfig": {
    "hoistingLimits": "dependencies"
  },
  "scripts": {
    "test": "TZ=UTC jest",
    "build": "npm run clean && npm run compile",
    "clean": "rm -rf ./dist",
    "compile": "rollup -c",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "homepage": "https://stytch.com/docs/api-reference/b2b/mobile-sdks/react-native/overview",
  "author": {
    "name": "Stytch",
    "url": "https://github.com/stytchauth"
  },
  "dependencies": {
    "@stytch/react-native-inappbrowser-reborn": "^3.7.2",
    "base-64": "1.0.0",
    "libphonenumber-js": "1.10.55",
    "lodash.debounce": "4.0.8",
    "lodash.merge": "4.6.2",
    "react-native-country-codes-picker": "2.3.5",
    "react-native-url-polyfill": "2.0.0",
    "react-native-uuid": "2.0.1",
    "utf8": "3.0.0"
  },
  "devDependencies": {
    "@babel/core": "7.28.5",
    "@jest/globals": "30.2.0",
    "@react-native/babel-preset": "0.81.1",
    "@react-native/codegen": "0.81.1",
    "@stytch/core": "workspace:*",
    "@stytch/internal-build-config": "workspace:*",
    "@stytch/internal-tsconfigs": "workspace:*",
    "@stytch/js-utils": "workspace:*",
    "@testing-library/react-native": "13.3.3",
    "@types/base-64": "1.0.0",
    "@types/jest": "30.0.0",
    "@types/jest-when": "3.5.2",
    "@types/lodash.debounce": "4.0.8",
    "@types/lodash.merge": "4.6.9",
    "@types/react": "19.2.2",
    "@types/react-dom": "^19",
    "@types/utf8": "3.0.3",
    "eslint-config-custom": "workspace:*",
    "jest": "30.2.0",
    "jest-when": "3.7.0",
    "magic-string": "0.30.17",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.4",
    "react-native-country-codes-picker": "patch:react-native-country-codes-picker@npm%3A2.3.5#~/.yarn/patches/react-native-country-codes-picker-npm-2.3.5-3de615b7fb.patch",
    "react-test-renderer": "19.1.0",
    "rollup": "4.60.1",
    "ts-jest": "29.4.5",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "react": ">= 17.0.2",
    "react-dom": ">= 17.0.2",
    "react-native": ">= 0.80.x"
  },
  "codegenConfig": {
    "name": "StytchReactNativeTurboModule",
    "type": "modules",
    "jsSrcsDir": "./src/native-module",
    "android": {
      "javaPackageName": "com.stytch.reactnativemodules"
    }
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:stytchauth/stytch-browser.git",
    "directory": "packages/react-native"
  },
  "publishConfig": {
    "access": "public"
  }
}
