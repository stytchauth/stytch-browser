{
  "compilerOptions": {
    "declaration": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "module": "commonjs",
    "target": "es2015",
    "sourceMap": true,
    "jsx": "react",
    "lib": ["es2022", "DOM"],
    "moduleResolution": "node",
    "strict": true,
    "allowJs": true,
    "outDir": "dist"
  },
  "exclude": ["node_modules", "dist"]
}
