{
  "name": "stytch-sdk-core",
  "version": "0.0.0",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "internal/*",
      "services/*",
      "packages/*"
    ]
  },
  "scripts": {
    "build": "NODE_OPTIONS=--max_old_space_size=4096 turbo run build",
    "build:clientside-services": "NODE_OPTIONS=--max_old_space_size=4096 turbo run build --filter=clientside-services...",
    "build:react": "NODE_OPTIONS=--max_old_space_size=4096 turbo run build --filter=react-demo...",
    "build:b2b:react": "NODE_OPTIONS=--max_old_space_size=4096 turbo run build --filter=react-b2b-demo...",
    "build:next": "NODE_OPTIONS=--max_old_space_size=4096 turbo run build --filter=next-demo...",
    "build:react-native": "NODE_OPTIONS=--max_old_space_size=4096 turbo run build --filter=react-native-demo...",
    "build:vanilla-js": "NODE_OPTIONS=--max_old_space_size=4096 turbo run build --filter=@stytch/vanilla-js...",
    "build:packages": "NODE_OPTIONS=--max_old_space_size=4096 turbo run build --filter='./packages/*'",
    "build-storybook": "turbo run build-storybook",
    "clean": "turbo run clean",
    "dev:b2b:react": "turbo run dev --filter=react-b2b-demo... --filter=clientside-services",
    "dev:react": "DEV_REACT_B2C=true turbo run dev --filter=react-demo... --filter=clientside-services",
    "dev:react:esbuild": "turbo run dev:esbuild --filter=react-demo... --filter=clientside-services",
    "dev:b2b:react:esbuild": "turbo run dev:esbuild --filter=react-b2b-demo... --filter=clientside-services",
    "dev:next": "turbo run dev --filter=next-demo... --filter=clientside-services",
    "dev:passkey-demo": "turbo run dev --filter=passkey-demo... --filter=clientside-services",
    "e2e:local": "BROWSER=none yarn workspace react-demo start & yarn workspace e2e-tests start",
    "test": "turbo run test",
    "test-storybook": "turbo run test-storybook",
    "test-storybook:static": "turbo run test-storybook:static",
    "typecheck": "turbo run typecheck",
    "lint": "prettier -c \"**/*\" && eslint '*/**/*.{js,jsx,ts,tsx}' --max-warnings=0",
    "blt": "yarn lint && turbo run build test",
    "format": "prettier --write \"**/*\" && eslint '*/**/*.{js,jsx,ts,tsx}' --fix --max-warnings=0",
    "version": "changeset version && yarn && yarn build:packages",
    "release": "yarn build:packages && yarn workspaces foreach -W --no-private --from '@stytch/*' npm publish --tolerate-republish --access public --tag v5 && yarn changeset tag",
    "strings": "turbo run strings"
  },
  "dependencies": {
    "react": "18.2.0"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.7",
    "@eslint/compat": "1.4.0",
    "@size-limit/preset-small-lib": "11.2.0",
    "@types/jest": "29.5.14",
    "@types/node": "18.17.19",
    "eslint": "9.36.0",
    "eslint-config-custom": "workspace:*",
    "jest": "29.7.0",
    "msw": "2.4.8",
    "msw-storybook-addon": "2.0.3",
    "prettier": "3.5.1",
    "size-limit": "11.2.0",
    "ts-jest": "29.2.5",
    "turbo": "2.4.2"
  },
  "engines": {
    "npm": ">=8.0.0",
    "node": "22.x"
  },
  "packageManager": "yarn@4.12.0",
  "resolutions": {
    "@storybook/preact@npm:8.6.4": "patch:@storybook/preact@npm%3A8.6.4#~/.yarn/patches/@storybook-preact-npm-8.6.4-f690163883.patch",
    "@types/react@npm:*": "npm:18.3.26"
  }
}
