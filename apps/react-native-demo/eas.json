{
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "development-local": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "android": {
        "credentialsSource": "local"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "image": "latest"
      },
      "ios": {
        "image": "latest"
      }
    },
    "preview-simulator": {
      "distribution": "internal",
      "ios": {
        "simulator": true,
        "image": "latest"
      }
    },
    "production": {}
  },
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": false
  }
}
